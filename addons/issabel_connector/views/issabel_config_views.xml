<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Vista de lista -->
        <record id="view_issabel_config_list" model="ir.ui.view">
            <field name="name">issabel.config.list</field>
            <field name="model">issabel.config</field>
            <field name="arch" type="xml">
                <list string="Configuraciones Issabel" 
                      decoration-success="state == 'connected'" 
                      decoration-danger="state == 'disconnected'">
                    <field name="name"/>
                    <field name="ami_host"/>
                    <field name="ami_port"/>
                    <field name="state" widget="badge" 
                           decoration-success="state == 'connected'"
                           decoration-danger="state == 'disconnected'"/>
                    <field name="last_connection" widget="relative"/>
                    <field name="auto_connect" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- Vista de formulario -->
        <record id="view_issabel_config_form" model="ir.ui.view">
            <field name="name">issabel.config.form</field>
            <field name="model">issabel.config</field>
            <field name="arch" type="xml">
                <form string="Configuración Issabel/Asterisk">
                    <header>
                        <!-- Botones de acción -->
                        <button name="action_test_connection" 
                                string="🔌 Probar Conexión" 
                                type="object" 
                                class="btn-secondary"/>
                        
                        <button name="action_connect_ami" 
                                string="▶️ Conectar Servicio AMI" 
                                type="object" 
                                class="btn-primary"
                                invisible="state == 'connected'"/>
                        
                        <button name="action_disconnect_ami" 
                                string="⏸️ Desconectar Servicio AMI" 
                                type="object" 
                                class="btn-warning"
                                invisible="state == 'disconnected'"/>
                        
                        <!-- Estado -->
                        <field name="state" widget="statusbar" 
                               statusbar_visible="connected,disconnected"/>
                    </header>
                    
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" 
                                    type="object" 
                                    name="action_connect_ami"
                                    icon="fa-play-circle"
                                    invisible="state == 'connected'">
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_text">Iniciar</span>
                                    <span class="o_stat_text">Servicio</span>
                                </div>
                            </button>
                            <button class="oe_stat_button" 
                                    type="object" 
                                    name="action_disconnect_ami"
                                    icon="fa-stop-circle"
                                    invisible="state == 'disconnected'">
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_text">Detener</span>
                                    <span class="o_stat_text">Servicio</span>
                                </div>
                            </button>
                        </div>

                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>

                        <!-- Alerta de estado -->
                        <div class="alert alert-success text-center" role="alert" invisible="state != 'connected'">
                            <h4><i class="fa fa-check-circle"/> Servicio AMI Conectado</h4>
                            <p class="mb-0">El servicio está escuchando eventos en tiempo real</p>
                        </div>

                        <div class="alert alert-warning text-center" role="alert" invisible="state != 'disconnected'">
                            <h4><i class="fa fa-exclamation-triangle"/> Servicio AMI Desconectado</h4>
                            <p class="mb-0">Presiona "Conectar Servicio AMI" para comenzar a recibir eventos</p>
                        </div>

                        <group>
                            <group string="🔌 Configuración de Conexión">
                                <field name="ami_host" placeholder="192.168.1.10"/>
                                <field name="ami_port"/>
                                <field name="ami_user" placeholder="admin"/>
                                <field name="ami_password"/>
                            </group>
                            <group string="⚙️ Opciones">
                                <field name="auto_connect" 
                                       help="Conectar automáticamente cuando Odoo inicie"/>
                                <field name="last_connection" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="📊 Estado de Conexión">
                                <group>
                                    <group string="Última Prueba">
                                        <field name="last_test_result" 
                                               widget="badge"
                                               decoration-success="last_test_result == 'success'"
                                               decoration-danger="last_test_result == 'failed'"/>
                                        <field name="last_test_message" 
                                               readonly="1" 
                                               widget="text"
                                               nolabel="1"/>
                                    </group>
                                </group>
                            </page>

                            <page string="ℹ️ Información">
                                <group>
                                    <div class="alert alert-info" role="alert">
                                        <h4>📘 Sobre el Servicio AMI</h4>
                                        <ul>
                                            <li><strong>Conexión Persistente:</strong> El servicio mantiene una conexión abierta con Asterisk</li>
                                            <li><strong>Eventos en Tiempo Real:</strong> Recibe notificaciones instantáneas de cambios</li>
                                            <li><strong>Auto-Reconexión:</strong> Si se pierde la conexión, intenta reconectar automáticamente</li>
                                            <li><strong>Thread Independiente:</strong> No bloquea las operaciones de Odoo</li>
                                        </ul>
                                        
                                        <h4 class="mt-3">📋 Eventos Capturados:</h4>
                                        <ul>
                                            <li><code>QueueMemberStatus</code> - Estado de agentes en colas</li>
                                            <li><code>QueueMemberPause</code> - Pausas de agentes</li>
                                            <li><code>QueueCallerJoin/Leave</code> - Llamadas entrando/saliendo</li>
                                            <li><code>AgentConnect/Complete</code> - Conexiones de agentes</li>
                                            <li><code>Hangup</code> - Llamadas finalizadas</li>
                                        </ul>
                                    </div>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista de búsqueda -->
        <record id="view_issabel_config_search" model="ir.ui.view">
            <field name="name">issabel.config.search</field>
            <field name="model">issabel.config</field>
            <field name="arch" type="xml">
                <search string="Buscar Configuración Issabel">
                    <field name="name"/>
                    <field name="ami_host"/>
                    <filter string="Conectados" 
                            name="connected" 
                            domain="[('state','=','connected')]"/>
                    <filter string="Desconectados" 
                            name="disconnected" 
                            domain="[('state','=','disconnected')]"/>
                    <filter string="Auto-Conectar" 
                            name="auto_connect" 
                            domain="[('auto_connect','=',True)]"/>
                </search>
            </field>
        </record>

        <!-- Acción -->
        <record id="action_issabel_config" model="ir.actions.act_window">
            <field name="name">Configuración Issabel/Asterisk</field>
            <field name="res_model">issabel.config</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Configura la conexión a Asterisk/Issabel
                </p>
                <p>
                    Necesitas crear una configuración para conectarte al servidor Asterisk.
                    Asegúrate de tener acceso al AMI (Asterisk Manager Interface).
                </p>
            </field>
        </record>

    </data>
</odoo>