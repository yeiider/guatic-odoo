<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dashboard_template" name="API Reports Dashboard">
        <t t-call="web.layout">
            <t t-call-assets="web.assets_backend" t-js="true" />
            <div class="container-fluid">
                <div id="loader-overlay" class="loader-overlay" style="display: none;">
                    <span id="loader-data" class="loader"></span>
                </div>

                <!-- Breadcrumb Navigation -->
                <div class="row mb-3">
                    <div class="col-6">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb bg-light p-3 rounded">
                                <li class="breadcrumb-item">
                                    <a
                                        href="/web#menu_id=asertis_canales_digitales_reports.api_reporting_main_menu&amp;action="
                                        class="text-decoration-none">
                                        <i class="fa fa-home me-1"></i>Asertis Canales Digitales
                                        Reportes </a>
                                </li>
                                <li class="breadcrumb-item active" aria-current="page">
                                    <i class="fa fa-chart-bar me-1"></i>Dashboard </li>
                            </ol>
                        </nav>
                    </div>
                    <div class=" col-6 d-flex justify-content-end align-items-center mb-2">
                        <!-- Botón de Regresar -->
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                            onclick="window.history.back();">
                            <i class="fa fa-arrow-left me-1"></i>Regresar </button>

                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div
                                class="card-header d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <h2 class="mb-0">Reportes</h2>


                                </div>
                                <div class="d-flex align-items-center" style="column-gap: 1rem;">
                                    <!-- Selector de Período -->
                                    <div class="mr-3">
                                        <label for="period_selector" class="mr-2">Período:</label>
                                        <select id="period_selector"
                                            class="form-control d-inline-block" style="width: auto;">
                                            <option value="today">Hoy</option>
                                            <option value="week">Esta semana</option>
                                            <option value="month">Este mes</option>
                                            <option value="last_month" selected="selected">Mes
                                                anterior</option>
                                        </select>
                                    </div>

                                    <!-- Selector de Configuración -->
                                    <select id="config_selector"
                                        class="form-control d-inline-block mr-2"
                                        style="width: auto;">
                                        <option value="">Todas las configuraciones</option>
                                    </select>

                                    <!-- Botones -->
                                    <button id="sync_btn" class="btn btn-primary ml-2">
                                        <i class="fa fa-refresh"></i> Sincronizar </button>
                                    <button id="realtime_btn" class="btn btn-info ml-2">
                                        <i class="fa fa-bolt"></i> Tiempo Real </button>
                                </div>
                            </div>

                            <div class="card-body">
                                <!-- Fecha de ultima sincronización -->
                                <div class="row mb-4">
                                    <div class="col-12 d-flex align-items-center"
                                        style="justify-content: end;padding-right: 1.5rem;">
                                        <div class="me-3" id="sync_status">
                                            <div class="d-flex align-items-center">
                                                <div id="sync_dot"
                                                    class="bg-success rounded-circle me-2"
                                                    style="width: 8px; height: 8px;"></div>
                                                <span id="sync_text" class="text-success fw-bold">
                                                    Sincronizado</span>
                                            </div>
                                        </div>
                                        <div class="text-muted small">
                                            <i class="fa fa-calendar"></i>
                                            <span id="last_sync_time">15 de Enero, 2024 - 14:30</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Tarjetas de resumen -->
                                <div class="row mb-4">
                                    <div class="col-md-3">
                                        <div class="card bg-primary text-white">
                                            <div class="card-body">
                                                <h4 id="total_sessions">0</h4>
                                                <p>Sesiones</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="card bg-success text-white">
                                            <div class="card-body">
                                                <h4 id="total_messages">0</h4>
                                                <p>Mensajes</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="card bg-info text-white">
                                            <div class="card-body">
                                                <h4 id="total_contacts">0</h4>
                                                <p>Contactos Únicos</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="card bg-warning text-white">
                                            <div class="card-body">
                                                <h4 id="avg_waiting_time">00:00:00</h4>
                                                <p>Tiempo de espera promedio</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Gráficos con detalles -->
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="card">
                                            <div class="card-header">
                                                <h5>Sesiones: <span id="sessions_total_display">0</span></h5>
                                            </div>
                                            <div class="card-body">
                                                <canvas id="sessions_chart" width="400" height="300"></canvas>
                                                <!-- Detalles específicos de sesiones -->
                                                <div id="sessions_details" class="mt-3">
                                                    <!-- Se llenará dinámicamente -->
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="card">
                                            <div class="card-header">
                                                <h5>Mensajes: <span id="messages_total_display">0</span></h5>
                                            </div>
                                            <div class="card-body">
                                                <canvas id="messages_chart" width="400" height="300"></canvas>
                                                <!-- Detalles específicos de mensajes -->
                                                <div id="messages_details" class="mt-3">
                                                    <!-- Se llenará dinámicamente -->
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="card">
                                            <div class="card-header">
                                                <h5>Tiempo de espera promedio: <span
                                                        id="waiting_time_display">00:00:00</span>
                                                </h5>
                                            </div>
                                            <div class="card-body">
                                                <canvas id="waiting_time_chart" width="400"
                                                    height="300"></canvas>
                                                <!-- Detalles específicos de tiempo -->
                                                <div id="waiting_time_details" class="mt-3">
                                                    <!-- Se llenará dinámicamente -->
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Tabla de detalles -->
                                <div class="row mt-4">
                                    <div class="col-12">
                                        <div class="card">
                                            <div class="card-header">
                                                <h5>Detalles por Bot</h5>
                                            </div>
                                            <div class="card-body">
                                                <div class="table-responsive">
                                                    <table id="details_table"
                                                        class="table table-striped">
                                                        <thead>
                                                            <tr>
                                                                <th>Bot</th>
                                                                <th>Platform</th>
                                                                <th>Sesiones</th>
                                                                <th>Mensajes Entrantes</th>
                                                                <th>Mensajes Salientes</th>
                                                                <th>Contactos Únicos</th>
                                                                <th>Sesiones Abandonadas</th>
                                                                <th>Sesiones con Panel</th>
                                                                <th>Tiempo Promedio Espera</th>
                                                                <th>Tiempo Promedio Sesión</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Loading Modal -->
            <div class="modal fade" id="loadingModal" tabindex="-1" role="dialog">
                <div class="modal-dialog modal-sm" role="document">
                    <div class="modal-content">
                        <div class="modal-body text-center">
                            <div class="spinner-border" role="status">
                                <span class="sr-only">Cargando...</span>
                            </div>
                            <p class="mt-2">Cargando datos...</p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>