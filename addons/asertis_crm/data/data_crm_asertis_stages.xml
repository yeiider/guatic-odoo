<odoo>
  <data noupdate="1">

    <record id="estado_nuevo" model="crm_asertis_stages">
        <field name="name">Nuevo</field>
        <field name="sequence">1</field>
        <field name="fold">False</field>
    </record>

    <record id="estado_contactado" model="crm_asertis_stages">
        <field name="name">Contactado</field>
        <field name="sequence">2</field>
        <field name="fold">False</field>
    </record>

    <record id="estado_seguimiento" model="crm_asertis_stages">
        <field name="name">Seguimiento</field>
        <field name="sequence">3</field>
        <field name="fold">False</field>
    </record>

    <record id="estado_negociacion" model="crm_asertis_stages">
        <field name="name">Negociación</field>
        <field name="sequence">4</field>
        <field name="fold">False</field>
    </record>

    <record id="estado_cerrado" model="crm_asertis_stages">
        <field name="name">Perdido</field>
        <field name="sequence">5</field>
        <field name="fold">True</field> <!-- opcional: perdido puede estar colapsado -->
    </record>

    <record id="estado_ganado" model="crm_asertis_stages">
        <field name="name">Ganado</field>
        <field name="sequence">6</field>
        <field name="fold">False</field>
    </record>

  </data>
</odoo>
