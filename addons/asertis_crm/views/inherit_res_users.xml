<odoo>


    <record id="asertis_crm_res_users_tree_inherit" model="ir.ui.view">
        <field name="name">asertir_crm.res.users.tree.inherit</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="area"/>
            </xpath>
        </field>
    </record>

    <record id="asertis_crm_res_users_form_inherit" model="ir.ui.view">
        <field name="name">asertis.crm.res.users.view.form.inherit</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
        
            <xpath expr="//field[@name='name']" position="before">
                <field name="area"/>
            </xpath>

        </field>
    </record>


</odoo>