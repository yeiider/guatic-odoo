<odoo>

    <!-- Vista de árbol -->
    <record id="view_tree_crm_asertis_stages" model="ir.ui.view"> 
        <field name="name">view.tree.crm.asertis.stages</field>
        <field name="model">crm_asertis_stages</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name"/>
                <field name="sequence"/>
                <field name="fold"/>
                <field name="create_date" string="Creado el"/> 
                <field name="create_uid" string="Creado por"/> 
            </list>
        </field>
    </record>


    <!-- Acción -->
    <record id="action_crm_asertis_stages" model="ir.actions.act_window"> 
        <field name="name">Etapas</field>
        <field name="res_model">crm_asertis_stages</field>
        <field name="view_mode">list</field>
    </record>


    <!-- Menuitem -->
    <menuitem id="menu_crm_asertis_stages" parent="menu_crm_asertis_servicios_p" name="Etapas" action="asertis_crm.action_crm_asertis_stages"/>



</odoo>