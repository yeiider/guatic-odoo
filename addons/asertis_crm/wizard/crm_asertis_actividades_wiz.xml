<odoo>

    <record id="view_form_crm_asertis_actividades_wizard" model="ir.ui.view">
        <field name="name">view.form.crm.asertis.actividades.wizard</field>
        <field name="model">crm_asertis_actividades_wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Actividad">
                <group>
                    <field name="actividad"/>
                    <field name="fecha"/>
                    <field name="descripcion"/>
                </group>
                <footer>
                    <button string="Guardar" type="object" name="action_guardar_actividad" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_crm_asertis_actividades_wizard" model="ir.actions.act_window">
        <field name="name">Registrar Actividad</field>
        <field name="res_model">crm_asertis_actividades_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
