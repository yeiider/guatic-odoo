<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Vista tipo árbol (lista) -->
        <record id="view_chat_provider_list" model="ir.ui.view">
            <field name="name">chat.provider.list</field>
            <field name="model">chat.provider</field>
            <field name="type">list</field>  <!-- Agregar esta línea -->
            <field name="arch" type="xml">
                <list string="Proveedores de Chat">
                    <field name="name" />
                    <field name="provider_type" />
                    <field name="is_active" />
                    <field name="base_url" />
                    <field name="allowed_channel_ids" widget="many2many_tags" />
                </list>
            </field>
        </record>

        <!-- Vista tipo formulario sin auth_token directo -->
        <record id="view_chat_provider_form" model="ir.ui.view">
            <field name="name">chat.provider.form</field>
            <field name="model">chat.provider</field>
            <field name="type">form</field>  <!-- Agregar esta línea también -->
            <field name="arch" type="xml">
                <form string="Proveedor de Chat">
                    <sheet>
                        <group>
                            <field name="name" />
                            <field name="provider_type" />
                            <field name="is_active" />
                        </group>
                        <group>
                            <field name="base_url" />
                            <!-- Quitar el campo auth_token directo -->
                            <!-- <field name="auth_token" /> -->
                            <field name="allowed_channel_ids" widget="many2many_tags" />
                            <field name="config_extra"
                                placeholder="{&quot;key&quot;: &quot;value&quot;}" />
                        </group>
                        <group string="Historial de Configuración">
                            <field name="historial_config"  />
                        </group>

                        <!-- Agregar sección para configurar el token -->
                        <group string="Configuración de Token">
                            <field name="auth_token" widget="text"
                                placeholder="Introduce el token aquí" />
                            <div class="oe_form_field o_field_widget o_field_text">
                                <label for="auth_token" class="o_label">Token de Autenticación</label>
                                <p class="o_field_description">
                                    Este token se usará para autenticar las solicitudes al proveedor
                                    de
                                    chat.
                                </p>
                            </div>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Acción -->
        <record id="action_chat_provider" model="ir.actions.act_window">
            <field name="name">Proveedores de Chat</field>
            <field name="res_model">chat.provider</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Configura los proveedores de chat que deseas usar.
                </p>
            </field>
        </record>

    </data>
</odoo>