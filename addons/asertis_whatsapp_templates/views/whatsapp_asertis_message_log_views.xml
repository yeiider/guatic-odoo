<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <!-- Vista de lista del historial -->
        <record id="view_whatsapp_message_log_list" model="ir.ui.view">
            <field name="name">whatsapp.message.log.list</field>
            <field name="model">whatsapp.asertis.message.log</field>
            <field name="arch" type="xml">
                <list string="Historial de Mensajes WhatsApp"
                    decoration-success="status == 'sent'"
                    decoration-danger="status == 'failed'"
                    decoration-warning="status == 'retry'"
                    decoration-info="status == 'pending'">
                    <field name="sent_date" />
                    <field name="template_name" />
                    <field name="partner_id" />
                    <field name="phone" />
                    <field name="status" widget="badge"
                        decoration-success="status == 'sent'"
                        decoration-danger="status == 'failed'"
                        decoration-warning="status == 'retry'"
                        decoration-info="status == 'pending'" />
                    <field name="user_id" />
                    <field name="retry_count" />
                    <field name="processing_time" string="Tiempo (ms)" />
                    <field name="company_id" groups="base.group_multi_company" />
                    <button name="action_retry_send" type="object"
                        icon="fa-refresh" title="Reintentar Envío"
                        invisible="[('status', '=', 'sent')]" />
                    <button name="action_view_template" type="object"
                        icon="fa-file-text-o" title="Ver Plantilla" />
                    <button name="action_show_details" type="object"
                        icon="fa-info-circle" title="Ver Detalles" />
                </list>
            </field>
        </record>

        <!-- Vista kanban del historial -->
        <record id="view_whatsapp_message_log_kanban" model="ir.ui.view">
            <field name="name">whatsapp.message.log.kanban</field>
            <field name="model">whatsapp.asertis.message.log</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column">
                    <field name="display_name" />
                    <field name="sent_date" />
                    <field name="template_name" />
                    <field name="partner_id" />
                    <field name="phone" />
                    <field name="status" />
                    <field name="status_color" />
                    <field name="retry_count" />
                    <field name="user_id" />
                    <templates>
                        <t t-name="kanban-box">
                            <div
                                t-attf-class="oe_kanban_card oe_kanban_global_click oe_kanban_color_#{record.status_color.raw_value}">
                                <div class="o_kanban_card_header">
                                    <div class="o_kanban_card_header_title">
                                        <div class="o_primary">
                                            <strong>
                                                <field name="template_name" />
                                            </strong>
                                        </div>
                                        <div class="o_secondary">
                                            <field name="sent_date" widget="datetime" />
                                        </div>
                                    </div>
                                    <div class="o_kanban_manage_button_section">
                                        <a class="o_kanban_manage_toggle_button" href="#">
                                            <i class="fa fa-ellipsis-v" role="img"
                                                aria-label="Manage"
                                                title="Manage" />
                                        </a>
                                    </div>
                                </div>
                                <div class="o_kanban_card_content">
                                    <div class="o_kanban_card_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <div t-if="record.partner_id.value"> 👤 <field
                                                    name="partner_id" />
                                            </div>
                                            <div> 📱 <field name="phone" />
                                            </div>
                                            <div t-if="record.retry_count.value > 0"> 🔄 <field
                                                    name="retry_count" /> reintentos </div>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <img
                                                t-att-src="kanban_image('res.users', 'avatar_128', record.user_id.raw_value)"
                                                t-att-title="record.user_id.value"
                                                t-att-alt="record.user_id.value"
                                                width="24" height="24"
                                                class="oe_kanban_avatar" />
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_manage_view">
                                    <div class="o_kanban_card_manage_section">
                                        <div t-if="record.status.raw_value != 'sent'">
                                            <a type="object" name="action_retry_send">🔄 Reintentar</a>
                                        </div>
                                        <div>
                                            <a type="object" name="action_view_template">📋 Ver
                                                Plantilla</a>
                                        </div>
                                        <div>
                                            <a type="object" name="action_show_details">ℹ️ Detalles</a>
                                        </div>
                                        <div t-if="record.partner_id.value">
                                            <a type="object" name="action_view_partner">👤 Ver
                                                Contacto</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Vista de formulario del historial -->
        <record id="view_whatsapp_message_log_form" model="ir.ui.view">
            <field name="name">whatsapp.message.log.form</field>
            <field name="model">whatsapp.asertis.message.log</field>
            <field name="arch" type="xml">
                <form string="Mensaje WhatsApp" create="false" edit="false">
                    <header>
                        <button name="action_retry_send" string="🔄 Reintentar Envío"
                            type="object" class="btn-primary"
                            invisible="[('status', '=', 'sent')]" />
                        <button name="action_view_template" string="📋 Ver Plantilla"
                            type="object" class="btn-secondary" />
                        <button name="action_view_partner" string="👤 Ver Contacto"
                            type="object" class="btn-secondary"
                            invisible="[('partner_id', '=', False)]" />
                        <button name="action_view_lead" string="🎯 Ver Oportunidad"
                            type="object" class="btn-secondary"
                            invisible="[('lead_id', '=', False)]"
                        />
                        <field name="status" widget="statusbar"
                            statusbar_visible="pending,sent,failed,retry" />
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" icon="fa-clock-o">
                                <field name="days_since_sent" widget="statinfo" string="Días Atrás" />
                            </button>
                            <button class="oe_stat_button" icon="fa-refresh"
                                invisible="[('retry_count', '=', 0)]"
                            >
                                <field name="retry_count" widget="statinfo" string="Reintentos" />
                            </button>
                            <button class="oe_stat_button" icon="fa-tachometer"
                                invisible="[('processing_time', '=', 0)]"
                            >
                                <field name="processing_time" widget="statinfo" string="Tiempo (ms)" />
                            </button>
                        </div>

                        <div class="oe_title">
                            <h1>
                                <field name="display_name" />
                            </h1>
                        </div>

                        <group>
                            <group name="message_info" string="Información del Mensaje">
                                <field name="template_id" />
                                <field name="template_name" readonly="1" />
                                <field name="template_type" readonly="1" />
                                <field name="sent_date" />
                                <field name="user_id" />
                                <field name="company_id" groups="base.group_multi_company" />
                            </group>
                            <group name="recipient_info" string="Información del Destinatario">
                                <field name="partner_id" />
                                <field name="lead_id" />
                                <field name="phone" />
                            </group>
                        </group>

                        <notebook>
                            <page string="Parámetros Enviados" name="params">
                                <group>
                                    <field name="params_display" widget="text" readonly="1" />
                                </group>
                            </page>

                            <page string="Respuesta de la API" name="response">
                                <group>
                                    <group name="response_info" string="Información de Respuesta">
                                        <field name="api_response_code" readonly="1" />
                                        <field name="processing_time" readonly="1" />
                                    </group>
                                </group>
                                <group name="response_data_group">
                                    <field name="response_data" widget="ace"
                                        options="{'mode': 'json'}"
                                        readonly="1" />
                                </group>
                            </page>

                            <page string="Errores" name="errors"
                                invisible="[('error_message', '=', False)]">
                                <group>
                                    <field name="error_message" widget="text" readonly="1" />
                                </group>
                            </page>

                            <page string="Seguimiento" name="tracking">
                                <group>
                                    <group name="delivery_info" string="Estado de Entrega">
                                        <field name="delivered_date" readonly="1" />
                                        <field name="read_date" readonly="1" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista de búsqueda del historial -->
        <record id="view_whatsapp_message_log_search" model="ir.ui.view">
            <field name="name">whatsapp.message.log.search</field>
            <field name="model">whatsapp.asertis.message.log</field>
            <field name="arch" type="xml">
                <search string="Buscar Mensajes">
                    <field name="template_name" string="Plantilla" />
                    <field name="partner_id" string="Contacto" />
                    <field name="phone" string="Teléfono" />
                    <field name="user_id" string="Usuario" />

                    <filter string="Enviados" name="sent" domain="[('status', '=', 'sent')]" />
                    <filter string="Fallidos" name="failed" domain="[('status', '=', 'failed')]" />
                    <filter string="Pendientes" name="pending" domain="[('status', '=', 'pending')]" />
                    <filter string="Reintentando" name="retry" domain="[('status', '=', 'retry')]" />

                    <separator />
                    <filter string="Con Errores" name="with_errors"
                        domain="[('error_message', '!=', False)]" />
                    <filter string="Con Reintentos" name="with_retries"
                        domain="[('retry_count', '>', 0)]" />

                    <separator />
                    <filter string="Hoy" name="today"
                        domain="[('sent_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))), 
                                ('sent_date', '&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)))]" />
                    <filter string="Esta Semana" name="this_week"
                        domain="[('sent_date', '&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]" />
                    <filter string="Este Mes" name="this_month"
                        domain="[('sent_date', '&gt;=', context_today().strftime('%Y-%m-01'))]" />

                    <separator />
                    <filter string="Mis Mensajes" name="my_messages"
                        domain="[('user_id', '=', uid)]" />

                    <group expand="1" string="Agrupar Por">
                        <filter string="Estado" name="group_status" context="{'group_by': 'status'}" />
                        <filter string="Plantilla" name="group_template"
                            context="{'group_by': 'template_name'}" />
                        <filter string="Usuario" name="group_user" context="{'group_by': 'user_id'}" />
                        <filter string="Fecha" name="group_date"
                            context="{'group_by': 'sent_date:day'}" />
                        <filter string="Contacto" name="group_partner"
                            context="{'group_by': 'partner_id'}" />
                        <filter string="Compañía" name="group_company"
                            context="{'group_by': 'company_id'}" groups="base.group_multi_company" />
                    </group>
                </search>
            </field>
        </record>

        <!-- Vista gráfico para dashboard -->
        <record id="view_whatsapp_message_log_graph" model="ir.ui.view">
            <field name="name">whatsapp.message.log.graph</field>
            <field name="model">whatsapp.asertis.message.log</field>
            <field name="arch" type="xml">
                <graph string="Estadísticas de Mensajes WhatsApp">
                    <field name="sent_date" type="row" interval="day" />
                    <field name="status" type="col" />
                </graph>
            </field>
        </record>

        <!-- Vista pivot para análisis -->
        <record id="view_whatsapp_message_log_pivot" model="ir.ui.view">
            <field name="name">whatsapp.message.log.pivot</field>
            <field name="model">whatsapp.asertis.message.log</field>
            <field name="arch" type="xml">
                <pivot string="Análisis de Mensajes WhatsApp">
                    <field name="sent_date" type="row" interval="month" />
                    <field name="status" type="col" />
                    <field name="template_name" type="row" />
                    <field name="user_id" type="row" />
                </pivot>
            </field>
        </record>
        <!-- Acción para la vista de logs -->
        <record id="action_whatsapp_asertis_message_log" model="ir.actions.act_window">
            <field name="name">Registro de Mensajes</field>
            <field name="res_model">whatsapp.asertis.message.log</field>
            <field name="view_mode">list,form,graph,pivot</field>
            <field name="search_view_id" ref="view_whatsapp_message_log_search"/>
        </record>

    </data>
</odoo>