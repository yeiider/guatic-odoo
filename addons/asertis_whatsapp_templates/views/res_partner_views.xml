<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extensión de la vista de formulario de contactos -->
    <record id="view_partner_form_whatsapp" model="ir.ui.view">
        <field name="name">res.partner.form.whatsapp</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <!-- Agregar botones en el header -->
            <button name="toggle_active" position="before">
                <button name="action_send_whatsapp" type="object"
                    class="btn-primary" string="📱 WhatsApp"
                    invisible="['|', ('whatsapp_opt_out', '=', True), ('has_valid_whatsapp', '=', False)]"
                    title="Enviar mensaje WhatsApp" />
                <button name="action_open_whatsapp_web" type="object"
                    class="btn-secondary" string="💬 WhatsApp Web"
                    invisible="['|', ('whatsapp_opt_out', '=', True), ('has_valid_whatsapp', '=', False)]"
                    title="Abrir chat en WhatsApp Web" />
            </button>

            <!-- Agregar botón de estadísticas WhatsApp -->
            <div name="button_box" position="inside">
                <button name="action_view_whatsapp_history" type="object"
                    class="oe_stat_button" icon="fa-whatsapp"
                    invisible="['whatsapp_count', '=', 0]">
                    <field name="whatsapp_count" widget="statinfo" string="Mensajes WhatsApp" />
                </button>
            </div>

            <!-- Extender información de contacto -->
            <field name="mobile" position="after">
                <field name="whatsapp_phone" />
                <field name="whatsapp_url" widget="url"
                    invisible="['|', ('whatsapp_url', '=', False)]"
                    string="Enlace WhatsApp" />
            </field>

            <!-- Configuración WhatsApp -->
            <field name="category_id" position="after">
                <field name="preferred_phone_whatsapp" />
                <field name="whatsapp_country_code" />
                <field name="whatsapp_opt_out" string="🚫 Excluir de WhatsApp" />
            </field>

            <!-- Campos computados invisibles -->
            <field name="supplier_rank" position="after">
                <field name="has_valid_whatsapp" invisible="1" />
                <field name="formatted_whatsapp_phone" invisible="1" />
            </field>

            <!-- Agregar pestaña WhatsApp -->
            <xpath expr="//notebook" position="inside">
                <page string="WhatsApp" name="whatsapp"
                    invisible="['whatsapp_count', '=', 0]">
                    <group>
                        <group name="whatsapp_info" string="Información WhatsApp">
                            <field name="formatted_whatsapp_phone" readonly="1"
                                string="Teléfono Formateado" />
                            <field name="has_valid_whatsapp" readonly="1" string="WhatsApp Válido" />
                            <field name="whatsapp_url" widget="url" readonly="1"
                                string="Enlace WhatsApp" />
                            <field name="whatsapp_opt_out" readonly="1"
                                string="Excluido de WhatsApp" />
                        </group>
                        <group name="whatsapp_stats" string="Estadísticas WhatsApp">
                            <field name="whatsapp_count" readonly="1" string="Mensajes Enviados" />
                            <field name="last_whatsapp_sent" readonly="1" string="Último Mensaje" />
                        </group>
                    </group>


                </page>
            </xpath>

        </field>
    </record>

</odoo>