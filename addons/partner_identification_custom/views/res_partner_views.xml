<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_form_inherit_identification" model="ir.ui.view">
        <field name="name">res.partner.form.identification</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <!-- Insertar después del campo 'email' -->
            <xpath expr="//field[@name='category_id']" position="before">
                <field name="personal_id_type"
                    invisible="is_company"
                    placeholder="Seleccione tipo de identificación" />
                <field name="personal_id_number"
                    invisible="is_company"
                    placeholder="Ingrese el número" />
            </xpath>
        </field>
    </record>
</odoo>